LOG_FILE=/logs/media_refresh.log
# LOG_RETENTION_COUNT=3
DEBUG=false

DEBOUNCE_SECONDS=10
QUEUE_FILE=/tmp/media_refresh_queue

# Jellyfin: Dashboard → API Keys (create one if needed)
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=YOUR_API_KEY
# JELLYFIN_EVENTS=Download,Upgrade,Rename,MovieDelete

# Emby: Dashboard → API Keys (create one if needed)
EMBY_URL=http://emby:8096
EMBY_API_KEY=YOUR_API_KEY
# EMBY_EVENTS=Download,Upgrade,Rename,MovieDelete

# Seerr: Settings → General → API Key
SEERR_URL=http://seerr:5055
SEERR_API_KEY=YOUR_API_KEY
# SEERR_EVENTS=Download,Upgrade,Rename
